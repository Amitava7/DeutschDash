generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  username  String   @unique
  password  String
  level     String   @default("B1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  decks            Deck[]
  practiceSessions PracticeSession[]
  cardProgress     UserCardProgress[]
}

model Deck {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  isDefault   Boolean  @default(false)
  userId      String?  @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcards Flashcard[]
}

model Flashcard {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  germanWord         String
  englishTranslation String
  level              String   @default("B1")
  deckId             String   @db.ObjectId
  createdAt          DateTime @default(now())

  deck         Deck               @relation(fields: [deckId], references: [id], onDelete: Cascade)
  userProgress UserCardProgress[]
}

model UserCardProgress {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String    @db.ObjectId
  flashcardId     String    @db.ObjectId
  nextReviewDate  DateTime  @default(now())
  currentInterval Int       @default(0)
  easeLevel       Int       @default(0)
  lastReviewedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
}

model PracticeSession {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  type           String
  topic          String?
  tense          String?
  level          String
  score          Int?
  totalQuestions Int?
  data           Json?
  userId         String   @db.ObjectId
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TenseExercise {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  tense         String
  sentence      String
  correctAnswer String
  hint          String
  level         String @default("B1")
}

model ReadingPassage {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  topic     String
  paragraph String
  questions Json
  level     String @default("B1")
}
